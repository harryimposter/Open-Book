# Copy this file to ".env" and fill in real values. ".env" is gitignored.
#
# GMAIL_APP_PASSWORD is a Google *App Password*, NOT your normal login password.
# It requires 2-Step Verification on the account. Create one here:
#   https://myaccount.google.com/apppasswords
# It is scoped to mail and revocable at any time without changing your password.

GMAIL_ADDRESS=your.account@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
